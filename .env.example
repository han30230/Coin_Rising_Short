# Binance (필수)
BINANCE_API_KEY=your_api_key
BINANCE_SECRET=your_secret
BINANCE_ENV=mainnet

# 시가총액 필터 (선택, CoinMarketCap)
# CMC_API_KEY를 비우면 시가총액 필터는 비활성화되고 기존과 동일하게 동작합니다.
CMC_API_KEY=your_cmc_api_key
MIN_MARKET_CAP_USD=100000000
MCAP_CACHE_TTL_SEC=900

# Mcap/FDV 필터 (선택, CoinGecko, 급등 후보 정렬 후 최종 단계)
FILTER_MCAP_FDV=true
MIN_MCAP_FDV_RATIO=0.4
COINGECKO_API_BASE=https://api.coingecko.com/api/v3
